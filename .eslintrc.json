{
    "env": {
        "browser": true,
        "es2022": true
    },
    "parserOptions": {
        "ecmaVersion": 2022,
        "sourceType": "module"
    },
    "rules": {
        "no-unused-vars": ["warn", { "argsIgnorePattern": "^_", "varsIgnorePattern": "^_" }],
        "no-undef": "error",
        "no-console": "off",
        "eqeqeq": ["error", "always"],
        "no-var": "error",
        "prefer-const": "warn",
        "semi": ["error", "always"],
        "no-duplicate-imports": "error",
        "no-unreachable": "error",
        "no-constant-condition": "warn"
    }
}
