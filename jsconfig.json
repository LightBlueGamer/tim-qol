{
  "compilerOptions": {
    "module": "ES2022",
    "target": "ES2022",
    "paths": {
      "@client/*": ["./foundry/client/*"],
      "@common/*": ["./foundry/common/*"]
    },
    "types": ["foundryvtt-simple-calendar"]
  },
  "exclude": ["node_modules", "**/node_modules/*"],
  "include": ["scripts/*.js", "foundry/client/client.mjs", "foundry/client/global.d.mts", "foundry/common/primitives/global.d.mts", "foundry/extra.d.ts"],
  "typeAcquisition": {
    "include": ["jquery"]
  }
}